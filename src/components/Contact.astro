---
/**
 * Contact.astro - Contact section for Gabriel's CV 2.0
 * PR4: Experience Timeline + Projects + Contact
 */

import { Phone, Mail, Linkedin } from 'lucide-astro';
---

<section id="contact" class="contact-section">
  <div class="contact-container">
    <!-- Section Title -->
    <h2 class="section-title" data-reveal data-i18n="contact.title">
      Contacto
      <span class="title-accent"></span>
    </h2>

    <!-- Contact Grid -->
    <div class="contact-grid">
      <!-- Phone -->
      <a href="tel:+34693298749" class="contact-item" data-reveal style="--delay: 0">
        <div class="contact-icon phone">
          <Phone size={24} />
        </div>
        <div class="contact-info">
          <span class="contact-label" data-i18n="contact.phone">Teléfono</span>
          <span class="contact-value">+34 693 298 749</span>
        </div>
      </a>

      <!-- Email -->
      <a href="mailto:19gdp97@gmail.com" class="contact-item" data-reveal style="--delay: 1">
        <div class="contact-icon email">
          <Mail size={24} />
        </div>
        <div class="contact-info">
          <span class="contact-label" data-i18n="contact.email">Correo electrónico</span>
          <span class="contact-value">19gdp97@gmail.com</span>
        </div>
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/GabrielDP97"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-item"
        data-reveal
        style="--delay: 2"
      >
        <div class="contact-icon github">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div class="contact-info">
          <span class="contact-label" data-i18n="contact.github">GitHub</span>
          <span class="contact-value">github.com/GabrielDP97</span>
        </div>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/angel-gabriel-dp"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-item"
        data-reveal
        style="--delay: 3"
      >
        <div class="contact-icon linkedin">
          <Linkedin size={24} />
        </div>
        <div class="contact-info">
          <span class="contact-label" data-i18n="contact.linkedin">LinkedIn</span>
          <span class="contact-value">angel-gabriel-dp</span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  /* Section */
  .contact-section {
    padding: 6rem 1.5rem;
    background-color: var(--bg-surface);
  }

  .contact-container {
    max-width: 900px;
    margin: 0 auto;
  }

  /* Section Title */
  .section-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    position: relative;
    display: inline-block;
    margin-bottom: 3rem;
  }

  .title-accent {
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 60%;
    height: 4px;
    background: linear-gradient(90deg, var(--neon-cyan), var(--neon-blue));
    border-radius: var(--radius-full);
  }

  /* Contact Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .contact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Contact Item */
  .contact-item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .contact-item:hover {
    border-color: var(--neon-cyan);
    box-shadow: 0 0 25px var(--accent-glow);
    transform: translateY(-2px);
  }

  /* Contact Icon */
  .contact-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-icon.phone {
    background: linear-gradient(135deg, var(--neon-cyan), var(--neon-blue));
    color: var(--bg-deep);
  }

  .contact-icon.email {
    background: linear-gradient(135deg, #ff6b6b, #feca57);
    color: var(--bg-deep);
  }

  .contact-icon.github {
    background: #24292f;
    color: #f6f8fa;
    border: 1px solid var(--border-default);
  }

  .contact-icon.github svg {
    fill: currentColor;
  }

  [data-theme="dark"] .contact-icon.github {
    background: #f6f8fa;
    border-color: #d0d7de;
    color: #24292f;
  }

  [data-theme="dark"] .contact-icon.github svg {
    fill: currentColor;
  }

  .contact-icon.linkedin {
    background: linear-gradient(135deg, #0077b5, #00a0dc);
    color: white;
  }

  /* Contact Info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .contact-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .contact-icon {
      width: 48px;
      height: 48px;
    }

    .contact-icon :global(svg) {
      width: 20px;
      height: 20px;
    }

    .contact-item {
      padding: 1.25rem;
    }

    .contact-value {
      font-size: 0.9375rem;
    }
  }
</style>