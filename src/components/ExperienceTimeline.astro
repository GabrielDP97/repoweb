---
/**
 * ExperienceTimeline.astro - Vertical Timeline with i18n
 * PR4: Single column timeline, icons and cards vertically centered together
 */

import { GraduationCap, BookOpen, Award, Briefcase, ArrowUp } from 'lucide-astro';
import esTranslations from '../i18n/es.json';

// Build entries from i18n (newest first)
const rawEntries = (esTranslations as any).experience?.entries;
const entries: any[] = Array.isArray(rawEntries) ? rawEntries : [];

const icons: Record<string, any> = { GraduationCap, BookOpen, Award, Briefcase };
---

<section id="experience" class="experience-section">
  <div class="experience-container">
    <h2 class="section-title">
      <span data-i18n="experience.title">Trayectoria</span>
      <span class="title-accent"></span>
    </h2>

    <div class="legend" data-reveal>
      <span class="legend-item work"><Briefcase size={14} /> <span data-i18n="experience.legend_work">Experiencia laboral</span></span>
      <span class="legend-item edu"><GraduationCap size={14} /> <span data-i18n="experience.legend_edu">Formación</span></span>
    </div>

    <div class="ascending-indicator" data-reveal>
      <ArrowUp size={16} />
      <span data-i18n="experience.ascending">Más reciente</span>
    </div>

    <!-- Vertical timeline -->
    <div class="v-timeline">
      <div class="v-spine"></div>
      {entries.map((entry: any, i: number) => {
        const iconKey = entry.icon || 'BookOpen';
        const Icon = icons[iconKey] || BookOpen;
        const yrs = entry.year === entry.endYear ? entry.year : `${entry.year}–${entry.endYear}`;
        return (
          <div class={`v-row ${entry.type}`} data-reveal style={`--delay: ${i}`}>
            <div class={`v-dot ${entry.type}`}>
              {Icon && <Icon size={14} />}
            </div>
            <div class={`v-card ${entry.type}`}>
              <span class="v-year">{yrs}</span>
              <h3 class="v-title" data-i18n={`experience.entries.${i}.title`}>{entry.title}</h3>
              <span class="v-org" data-i18n={`experience.entries.${i}.org`}>{entry.org}</span>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .experience-section { padding: 6rem 1.5rem; background-color: var(--bg-surface); }
  .experience-container { max-width: 900px; margin: 0 auto; }

  .section-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    position: relative;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .title-accent {
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 60%;
    height: 4px;
    background: linear-gradient(90deg, var(--neon-cyan), var(--neon-blue));
    border-radius: var(--radius-full);
  }

  .legend { display: flex; gap: 1.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .legend-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 500; }
  .legend-item.work { color: var(--neon-cyan); }
  .legend-item.edu { color: var(--neon-purple); }

  /* Work entries: cyan glow spine segment + cyan dot/card */
  .v-row.work .v-spine-segment { background: var(--neon-cyan); }
  .v-row.work .v-dot {
    background: linear-gradient(135deg, var(--neon-cyan), var(--neon-blue));
    border-color: var(--neon-cyan);
    color: var(--bg-deep);
    box-shadow: 0 0 12px rgba(75, 243, 200, 0.4);
  }
  .v-row.work .v-card {
    border-left-color: var(--neon-cyan);
  }
  .v-row.work .v-card:hover {
    border-color: var(--neon-cyan);
    box-shadow: 0 0 20px rgba(75, 243, 200, 0.2);
  }
  .v-row.work .v-year {
    background: rgba(75, 243, 200, 0.15);
    color: var(--neon-cyan);
  }

  .ascending-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    padding: 0.5rem 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .ascending-indicator svg { color: var(--accent-primary); animation: bounce-up 1.5s ease-in-out infinite; }

  @keyframes bounce-up {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Timeline: relative container with absolute spine */
  .v-timeline {
    position: relative;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Vertical line (spine) */
  .v-spine {
    position: absolute;
    left: 17px; /* centers on a 36px dot at left: 0 */
    top: 18px;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--neon-purple), var(--border-default) 20%, var(--border-default) 80%, transparent);
  }

  /* Each row: dot + card, vertically centered */
  .v-row {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  /* Dot: 36x36 circle on the spine line */
  .v-dot {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 2;
    background: var(--bg-elevated);
    border: 2px solid var(--neon-purple);
    color: var(--neon-purple);
  }

  /* Card: next to the dot, centered vertically with it */
  .v-card {
    flex: 1;
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    border-left: 3px solid var(--neon-purple);
    border-radius: var(--radius-lg);
    padding: 0.75rem 1rem;
    margin-left: 1rem;
    transition: all var(--transition-base);
  }

  .v-card:hover {
    border-color: var(--neon-purple);
    box-shadow: 0 4px 15px rgba(167, 139, 250, 0.2);
  }

  .v-year {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    font-weight: 500;
    border-radius: var(--radius-full);
    padding: 0.15rem 0.5rem;
    margin-bottom: 0.3rem;
    background: rgba(167, 139, 250, 0.15);
    color: var(--neon-purple);
  }

  .v-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.15rem;
    line-height: 1.3;
  }

  .v-org {
    display: block;
    font-size: 0.6875rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .v-row[data-reveal] { transition-delay: calc(var(--delay, 0) * 100ms); }

  @media (max-width: 640px) {
    .v-timeline { max-width: 100%; }
    .v-title { font-size: 0.875rem; }
    .v-org { font-size: 0.625rem; }
    .v-card { padding: 0.625rem 0.875rem; }
  }
</style>