---
/**
 * Hero.astro - Full viewport hero section for Gabriel's CV 2.0
 * PR3: Content Components
 */

import { Mail, Phone, Github, Linkedin, MapPin, ChevronDown } from 'lucide-astro';
import profileImg from '../assets/profile.webp';
---

<section id="hero" class="hero-section">
  <div class="hero-container">
    <div class="hero-content">
      <!-- Profile Photo -->
      <div class="hero-photo" data-reveal>
        <div class="photo-wrapper">
          <img
            src={profileImg.src}
            alt="Ángel Gabriel Delgado Pérez - Full Stack Developer"
            width="280"
            height="280"
            loading="eager"
          />
          <div class="photo-glow"></div>
        </div>
      </div>

      <!-- Text Content -->
      <div class="hero-text">
        <!-- Name -->
<h1 class="hero-name" data-reveal data-i18n="hero.name">
           Ángel Gabriel Delgado Pérez
         </h1>

        <!-- Role -->
        <p class="hero-role neon-gradient-text" data-reveal data-i18n="hero.role">
          Desarrollador Full Stack
        </p>

        <!-- Location -->
        <div class="hero-location" data-reveal>
          <MapPin size={18} class="location-icon" />
          <span data-i18n="hero.location">Algeciras, España</span>
        </div>

        <!-- Tagline -->
        <p class="hero-tagline" data-reveal>
          <span data-i18n="hero.tagline">Desarrollador con background en educación y ciberseguridad, creando soluciones web escalables con pasión por el código limpio y la experiencia de usuario.</span>
        </p>

        <!-- CTAs -->
        <div class="hero-ctas" data-reveal>
          <a href="#contact" class="btn btn-primary" data-i18n="hero.cta_contact">
            Contactar
          </a>
          <a href="/repoweb/CV-Angel-Gabriel-Delgado-Perez.pdf" download class="btn btn-secondary" type="button" data-i18n="hero.cta_download">
            Descargar CV
          </a>
        </div>

        <!-- Contact Icons -->
        <div class="hero-contacts" data-reveal>
          <a href="tel:+34693298749" class="contact-icon" aria-label="Teléfono">
            <Phone size={20} />
          </a>
          <a href="mailto:19gdp97@gmail.com" class="contact-icon" aria-label="Email">
            <Mail size={20} />
          </a>
          <a href="https://github.com/GabrielDP97" target="_blank" rel="noopener noreferrer" class="contact-icon" aria-label="GitHub">
            <Github size={20} />
          </a>
          <a href="https://www.linkedin.com/in/angel-gabriel-dp" target="_blank" rel="noopener noreferrer" class="contact-icon" aria-label="LinkedIn">
            <Linkedin size={20} />
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="scroll-indicator" data-reveal>
      <a href="#about" class="scroll-link" aria-label="Ir a Sobre mí">
        <ChevronDown size={32} class="scroll-icon" />
      </a>
    </div>
  </div>
</section>

<style>
  /* Hero Section */
  .hero-section {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem 4rem;
    position: relative;
    background-color: var(--bg-deep);
  }

  .hero-container {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    width: 100%;
  }

  /* Desktop: Photo on left */
  @media (min-width: 768px) {
    .hero-content {
      grid-template-columns: auto 1fr;
      gap: 3rem;
    }
  }

  /* Photo */
  .hero-photo {
    display: flex;
    justify-content: center;
  }

  .photo-wrapper {
    position: relative;
    width: 220px;
    height: 220px;
  }

  @media (min-width: 768px) {
    .photo-wrapper {
      width: 280px;
      height: 280px;
    }
  }

  .photo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid var(--border-default);
    position: relative;
    z-index: 1;
  }

  .photo-glow {
    position: absolute;
    top: -8px;
    left: -8px;
    right: -8px;
    bottom: -8px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--neon-cyan), var(--neon-blue), var(--neon-purple));
    opacity: 0.6;
    z-index: 0;
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% {
      opacity: 0.4;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(1.05);
    }
  }

  /* Text Content */
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .hero-text {
      align-items: flex-start;
      text-align: left;
    }
  }

  /* Name */
  .hero-name {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-primary);
    margin: 0;
  }

  @media (min-width: 768px) {
    .hero-name {
      font-size: 3.5rem;
    }
  }

  /* Role */
  .hero-role {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
  }

  @media (min-width: 768px) {
    .hero-role {
      font-size: 1.75rem;
    }
  }

  /* Location */
  .hero-location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 1rem;
    margin-top: 0.25rem;
  }

  .location-icon {
    color: var(--accent-primary);
  }

  /* Tagline */
  .hero-tagline {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.7;
    max-width: 520px;
    margin-top: 0.5rem;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  @media (min-width: 768px) {
    .hero-ctas {
      justify-content: flex-start;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.75rem;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
    text-decoration: none;
    border: 2px solid transparent;
  }

  .btn-primary {
    background: var(--neon-cyan);
    color: var(--bg-deep);
    border-color: var(--neon-cyan);
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--neon-cyan);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border-color: var(--border-default);
  }

  .btn-secondary:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }

  /* Contact Icons */
  .hero-contacts {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.25rem;
  }

  @media (min-width: 768px) {
    .hero-contacts {
      justify-content: flex-start;
    }
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
    transition: all var(--transition-fast);
  }

  .contact-icon:hover {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
    transform: translateY(-3px);
    box-shadow: 0 0 15px var(--accent-glow);
  }

  .contact-icon[aria-label="GitHub"] {
    transition: all var(--transition-fast);
  }

  [data-theme="dark"] .contact-icon[aria-label="GitHub"] {
    background: white;
    color: #24292e;
    filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.3));
  }

  [data-theme="dark"] .contact-icon[aria-label="GitHub"]:hover {
    color: #24292e;
    border-color: white;
    transform: translateY(-3px);
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.4);
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: var(--text-muted);
    transition: all var(--transition-fast);
    border-radius: 50%;
  }

  .scroll-link:hover {
    color: var(--accent-primary);
  }

  .scroll-icon {
    animation: bounce-down 2s ease-in-out infinite;
  }

  @keyframes bounce-down {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  /* Responsive: center photo on mobile */
  @media (max-width: 767px) {
    .photo-wrapper {
      width: 180px;
      height: 180px;
    }
  }
</style>