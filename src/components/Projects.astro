---
/**
 * Projects.astro - Projects section for Gabriel's CV 2.0
 * PR4: Experience Timeline + Projects + Contact
 */

import { Github, ExternalLink } from 'lucide-astro';
---

<section id="projects" class="projects-section">
  <div class="projects-container">
    <!-- Section Title -->
    <h2 class="section-title" data-reveal data-i18n="projects.title">
      Proyectos
      <span class="title-accent"></span>
    </h2>

    <!-- Projects Grid -->
    <div class="projects-grid">
      <!-- CheckList Shop Card -->
      <article class="project-card" data-reveal style="--delay: 0">
        <div class="card-header">
          <h3 class="project-name" data-i18n="projects.checklist_shop.name">CheckList Shop</h3>
          <div class="project-badges">
            <span class="tech-badge kotlin">Kotlin</span>
            <span class="tech-badge sqlite">SQLite</span>
            <span class="tech-badge room">Room</span>
            <span class="tech-badge mvc">MVC</span>
          </div>
        </div>
<p class="project-description" data-i18n="projects.checklist_shop.description">
          Aplicación Android de comercio electrónico local desarrollada en Kotlin con SQLite y Room para persistencia de datos. Implementación del patrón MVC con gestión de productos, carrito de compras y lista de deseos.
        </p>
        <div class="card-footer">
          <a
            href="https://github.com/GabrielDP97/CheckListShop"
            target="_blank"
            rel="noopener noreferrer"
            class="project-link"
          >
            <Github size={18} />
            <span data-i18n="projects.view_code">Ver código fuente</span>
            <ExternalLink size={14} />
          </a>
        </div>
      </article>

      <!-- StockControl Card -->
      <article class="project-card" data-reveal style="--delay: 1">
        <div class="card-header">
          <h3 class="project-name" data-i18n="projects.stock_control.name">StockControl</h3>
          <div class="project-badges">
            <span class="tech-badge js">JavaScript</span>
            <span class="tech-badge css">CSS</span>
            <span class="tech-badge html">HTML</span>
            <span class="tech-badge docker">Docker</span>
            <span class="tech-badge react">React</span>
            <span class="tech-badge tailwind">Tailwind</span>
          </div>
        </div>
        <p class="project-description" data-i18n="projects.stock_control.description">
          Sistema de gestión de inventario desarrollado en React con backend en Node.js. Frontend con Tailwind CSS y diseño responsive. Contenedores Docker para despliegue.
        </p>
        <div class="card-footer">
          <a
            href="https://github.com/GabrielDP97/StockControl"
            target="_blank"
            rel="noopener noreferrer"
            class="project-link"
          >
            <Github size={18} />
            <span data-i18n="projects.view_code">Ver código fuente</span>
            <ExternalLink size={14} />
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  /* Section */
  .projects-section {
    padding: 6rem 1.5rem;
    background-color: var(--bg-deep);
  }

  .projects-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Section Title */
  .section-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    position: relative;
    display: inline-block;
    margin-bottom: 3rem;
  }

  .title-accent {
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 60%;
    height: 4px;
    background: linear-gradient(90deg, var(--neon-cyan), var(--neon-blue));
    border-radius: var(--radius-full);
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Project Card */
  .project-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--neon-cyan), var(--neon-blue));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-base);
  }

  .project-card:hover {
    border-color: var(--neon-cyan);
    box-shadow: 0 0 30px var(--accent-glow), 0 8px 40px rgba(0, 0, 0, 0.15);
    transform: translateY(-4px);
  }

  .project-card:hover::before {
    transform: scaleX(1);
  }

  /* Stagger animation */
  .project-card[data-reveal] {
    transition-delay: calc(var(--delay, 0) * 150ms);
  }

  /* Card Header */
  .card-header {
    margin-bottom: 1.25rem;
  }

  .project-name {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  /* Tech Badges */
  .project-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .tech-badge.kotlin {
    background: rgba(123, 97, 255, 0.15);
    color: #7b61ff;
    border: 1px solid rgba(123, 97, 255, 0.3);
  }

  .tech-badge.sqlite {
    background: rgba(0, 122, 204, 0.15);
    color: #007acc;
    border: 1px solid rgba(0, 122, 204, 0.3);
  }

  .tech-badge.room {
    background: rgba(227, 119, 50, 0.15);
    color: #e37732;
    border: 1px solid rgba(227, 119, 50, 0.3);
  }

  .tech-badge.mvc {
    background: rgba(72, 199, 142, 0.15);
    color: #48c78e;
    border: 1px solid rgba(72, 199, 142, 0.3);
  }

  .tech-badge.js {
    background: rgba(247, 223, 30, 0.15);
    color: #f7df1e;
    border: 1px solid rgba(247, 223, 30, 0.3);
  }

  .tech-badge.css {
    background: rgba(38, 77, 228, 0.15);
    color: #264de4;
    border: 1px solid rgba(38, 77, 228, 0.3);
  }

  .tech-badge.html {
    background: rgba(227, 76, 38, 0.15);
    color: #e34c26;
    border: 1px solid rgba(227, 76, 38, 0.3);
  }

  .tech-badge.docker {
    background: rgba(29, 99, 209, 0.15);
    color: #1d63d1;
    border: 1px solid rgba(29, 99, 209, 0.3);
  }

  .tech-badge.react {
    background: rgba(97, 218, 251, 0.15);
    color: #61dafb;
    border: 1px solid rgba(97, 218, 251, 0.3);
  }

  .tech-badge.tailwind {
    background: rgba(6, 182, 212, 0.15);
    color: #06b6d4;
    border: 1px solid rgba(6, 182, 212, 0.3);
  }

  /* Dark theme badge adjustments */
  :global([data-theme="dark"]) .tech-badge.kotlin {
    background: rgba(123, 97, 255, 0.25);
    color: #a78bfa;
  }

  :global([data-theme="dark"]) .tech-badge.sqlite {
    background: rgba(0, 122, 204, 0.25);
    color: #58a6ff;
  }

  :global([data-theme="dark"]) .tech-badge.room {
    background: rgba(227, 119, 50, 0.25);
    color: #f0883e;
  }

  :global([data-theme="dark"]) .tech-badge.mvc {
    background: rgba(72, 199, 142, 0.25);
    color: #3fb950;
  }

  :global([data-theme="dark"]) .tech-badge.js {
    background: rgba(247, 223, 30, 0.25);
    color: #f0e14a;
  }

  :global([data-theme="dark"]) .tech-badge.css {
    background: rgba(38, 77, 228, 0.25);
    color: #58a6ff;
  }

  :global([data-theme="dark"]) .tech-badge.html {
    background: rgba(227, 76, 38, 0.25);
    color: #f97316;
  }

  :global([data-theme="dark"]) .tech-badge.docker {
    background: rgba(29, 99, 209, 0.25);
    color: #58a6ff;
  }

  :global([data-theme="dark"]) .tech-badge.react {
    background: rgba(97, 218, 251, 0.25);
    color: #79c0ff;
  }

  :global([data-theme="dark"]) .tech-badge.tailwind {
    background: rgba(6, 182, 212, 0.25);
    color: #22d3ee;
  }

  /* Project Description */
  .project-description {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  /* Card Footer */
  .card-footer {
    padding-top: 1rem;
    border-top: 1px solid var(--border-muted);
  }

  .local-note {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* Project Link */
  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--accent-primary);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .project-link:hover {
    color: var(--neon-cyan);
  }

  .project-link :global(svg:last-of-type) {
    transition: transform var(--transition-fast);
  }

  .project-link:hover :global(svg:last-of-type) {
    transform: translate(2px, -2px);
  }
</style>