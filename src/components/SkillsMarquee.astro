</div>

<script>
  function initHardSkillsMarquee(track: HTMLElement) {
    // Single copy width (1/3 of total — 3 identical copies)
    const singleCopyWidth = track.scrollWidth / 3;
    let pos = 0;
    let lastTimestamp = 0;
    const speed = 0.04; // pixels per ms
    let paused = false;

    const wrapper = track.closest('.marquee-wrapper');
    if (wrapper) {
      wrapper.addEventListener('mouseenter', () => { paused = true; });
      wrapper.addEventListener('mouseleave', () => { paused = false; });
    }

    const move = (timestamp: number) => {
      if (!paused) {
        if (lastTimestamp === 0) lastTimestamp = timestamp;
        const delta = timestamp - lastTimestamp;
        lastTimestamp = timestamp;
        pos += speed * delta;

        // Seamless wrap at single copy boundary
        if (pos >= singleCopyWidth) {
          pos -= singleCopyWidth;
        }

        track.style.transform = `translateX(-${pos}px)`;
      }
      requestAnimationFrame(move);
    };

    requestAnimationFrame(move);
  }

  document.querySelectorAll<HTMLElement>('.skills-marquee .marquee-track').forEach(track => {
    initHardSkillsMarquee(track);
  });
</script>